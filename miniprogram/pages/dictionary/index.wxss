@import '../../app.wxss';
.tabs-row { display: flex; gap: 20px; margin-bottom: 12px; }
.tabchip { color: #6D8090; font-size: 14px; padding-bottom: 4px; border-bottom: 2px solid transparent; }
.tabchip.active { color: #65E8FF; border-bottom-color: #3AD9F7; }
.dict-row { padding: 12px; border-bottom: 1px solid #1F3B55; }
.dict-name { color: #E0F0FF; font-size: 14px; }
.del-btn { color: #FF6B6B; font-size: 13px; padding: 2px 8px; }
.add-row { display: flex; gap: 6px; padding: 12px; align-items: center; flex-wrap: wrap; }
.add-row .input-dark { flex: 1; min-width: 80px; }
