@import '../../app.wxss';
.mode-select { margin: 12px; padding: 12px; }
.chip { padding: 6px 14px; border-radius: 20px; border: 1px solid #2A4A6A; color: #6D8090; font-size: 13px; }
.chip.active { background: #3AD9F7; color: #0A1628; border-color: #3AD9F7; }
.picker-link { color: #65E8FF; font-size: 13px; text-decoration: underline; }
.result-panel { margin: 12px; padding: 12px; }
.result-title { color: #65E8FF; font-size: 14px; margin-bottom: 8px; display: block; }
.result-scroll { background: #0A1628; border: 1px solid #1F3B55; border-radius: 8px; padding: 10px; max-height: 300px; }
.mono-text { color: #E0F0FF; font-size: 12px; font-family: monospace; white-space: pre-wrap; word-break: break-all; }
