<!-- pages/activation/index.wxml -->
<wxs module="c" src="../../theme/colors.wxs" />
<view class="page page-dark">
  <view class="page-title">激活管理</view>
  <text class="mono-label pad-h">管理巨龙功能模块激活状态</text>

  <view class="panel-bg act-panel">
    <view class="form-sec-title">设备信息</view>
    <view class="form-item">
      <text class="form-label">序列号</text>
      <text class="mono-tag">{{serial || '--'}}</text>
    </view>
    <view class="form-item">
      <text class="form-label">固件版本</text>
      <text class="mono-tag">{{fwVersion || '--'}}</text>
    </view>
    <view class="form-item">
      <text class="form-label">激活状态</text>
      <text class="mono-tag {{activated ? 'green' : 'red'}}">{{activated ? '已激活' : '未激活'}}</text>
    </view>
  </view>

  <view class="panel-bg act-panel" wx:if="{{!activated}}">
    <view class="form-sec-title">激活设备</view>
    <view class="form-item-vert">
      <text class="form-label">激活码 (Base64)</text>
      <textarea class="input-dark area" value="{{actCode}}" bindinput="onActCode" placeholder="输入从授权渠道获取的激活码" auto-height maxlength="-1" />
    </view>
    <view class="action-row">
      <button class="btn-gold" bindtap="activateDevice" loading="{{activating}}">{{activating ? '激活中...' : '激活'}}</button>
    </view>
  </view>

  <view class="panel-bg act-panel" wx:if="{{activated}}">
    <view class="form-sec-title">已激活的功能</view>
    <view class="license-item" wx:for="{{licenses}}" wx:key="id">
      <view class="row space-between v-center">
        <view>
          <text class="license-name">{{item.module}}</text>
          <text class="mono-tag">{{item.id}}</text>
        </view>
        <text class="license-exp">到期: {{item.expiry || '永久'}}</text>
      </view>
    </view>
    <view class="action-row">
      <button class="btn-outline trash-btn" bindtap="deactivateDevice">撤销激活</button>
    </view>
  </view>

  <!-- 卡槽轮询延迟 -->
  <view class="panel-bg act-panel">
    <view class="form-sec-title">卡槽轮询延迟</view>
    <text class="mono-label">调整射频场轮询频率。值越小读卡响应越快但更耗电，值越大越省电但响应慢。修改后自动持久化到设备 flash。</text>
    <view class="form-item">
      <text class="form-label">当前值</text>
      <text class="mono-tag">{{pollingDelay !== null ? pollingDelay + ' ms' : '加载中...'}}</text>
    </view>
    <view class="form-item">
      <text class="form-label">延迟 (ms)</text>
      <input class="input-dark input-sm" value="{{pollingInput}}" bindinput="onPollingInput" type="number" placeholder="ms" />
      <button class="btn-cyan-sm" bindtap="savePollingDelay" loading="{{savingPolling}}">保存</button>
    </view>
    <view wx:if="{{pollingMsg}}" class="polling-msg {{pollingOk ? 'green' : 'red'}}">{{pollingMsg}}</view>
  </view>
</view>
